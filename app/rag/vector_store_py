import os
import json
import faiss
import numpy as np

from app.rag.embeddings import (
    generate_embedding,
    generate_query_embedding,
)
from app.utils.config import settings


INDEX_FILE = os.path.join(settings.CHROMA_DB_PATH, "faiss.index")
METADATA_FILE = os.path.join(settings.CHROMA_DB_PATH, "metadata.json")


class FAISSVectorStore:

    def __init__(self):

        os.makedirs(settings.CHROMA_DB_PATH, exist_ok=True)

        self.dimension = 768

        self.index = None
        self.metadata = []

        self.load()

    def load(self):

        if os.path.exists(INDEX_FILE):

            self.index = faiss.read_index(INDEX_FILE)

        else:

            self.index = faiss.IndexFlatL2(self.dimension)

        if os.path.exists(METADATA_FILE):

            with open(METADATA_FILE, "r", encoding="utf-8") as f:

                self.metadata = json.load(f)

        else:

            self.metadata = []

    def save(self):

        faiss.write_index(self.index, INDEX_FILE)

        with open(METADATA_FILE, "w", encoding="utf-8") as f:

            json.dump(self.metadata, f, indent=4)


store = FAISSVectorStore()



def add_document_chunks(doc_id: int, file_name: str, chunks: list[str]) -> int:
    """
    Generate embeddings and store them in FAISS.
    """

    if not chunks:
        return 0

    vectors = []

    for i, chunk in enumerate(chunks):

        embedding = generate_embedding(chunk)

        if not embedding:
            continue

        vectors.append(embedding)

        store.metadata.append(
            {
                "doc_id": str(doc_id),
                "file_name": file_name,
                "chunk_index": i,
                "text": chunk,
            }
        )

    if not vectors:
        return 0

    vectors = np.array(vectors, dtype=np.float32)

    store.index.add(vectors)

    store.save()

    print(f"✅ Added {len(vectors)} chunks for {file_name}")

    return len(vectors)


def search_similar(query: str, n_results: int = 5) -> list[dict]:
    """
    Search FAISS for similar document chunks.
    """

    if store.index.ntotal == 0:
        return []

    embedding = generate_query_embedding(query)

    if not embedding:
        return []

    query_vector = np.array([embedding], dtype=np.float32)

    distances, indices = store.index.search(
        query_vector,
        min(n_results, store.index.ntotal)
    )

    results = []

    for idx in indices[0]:

        if idx == -1:
            continue

        if idx >= len(store.metadata):
            continue

        item = store.metadata[idx]

        results.append(
            {
                "text": item["text"],
                "source": item["file_name"],
                "doc_id": item["doc_id"],
            }
        )

    return results




def delete_document_chunks(doc_id: int):
    """
    Delete all chunks belonging to a document and rebuild the FAISS index.
    """

    doc_id = str(doc_id)

    remaining = [
        item for item in store.metadata
        if item["doc_id"] != doc_id
    ]

    if len(remaining) == len(store.metadata):
        return

    store.metadata = remaining

    store.index = faiss.IndexFlatL2(store.dimension)

    vectors = []

    for item in store.metadata:

        embedding = generate_embedding(item["text"])

        if embedding:
            vectors.append(embedding)

    if vectors:
        store.index.add(
            np.array(vectors, dtype=np.float32)
        )

    store.save()


def get_collection_stats() -> dict:
    """
    Return FAISS knowledge base statistics.
    """

    return {
        "total_chunks": store.index.ntotal,
        "collection_name": "FAISS Knowledge Base"
    }